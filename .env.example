# Copy this file to .env.local (git-ignored) and fill in the values.
#
# VITE_API_URL: base URL of the deployed backend.
# After running `cd backend && make deploy`, the SAM output prints the URL.
# For local development with `make local`: use http://localhost:4000
#
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# Qdrant Cloud — used by the indexing script and Lambda functions
QDRANT_URL=https://xxxxxxxx.sa-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
